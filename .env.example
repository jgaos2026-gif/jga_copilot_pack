# JGA Enterprise OS - Environment Configuration
# Copy this file to .env and update with your actual values
# NEVER commit .env to git

# ==========================================
# APPLICATION SETTINGS
# ==========================================
NODE_ENV=development
PORT=3000
HOSTNAME=0.0.0.0
DOMAIN=localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
LOG_LEVEL=info
DEBUG=false

# ==========================================
# DATABASE
# ==========================================
# PostgreSQL Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=jga_enterprise
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_postgres_password

# Full DATABASE URL (optional, used if provided)
DATABASE_URL=postgresql://postgres:your_secure_postgres_password@localhost:5432/jga_enterprise

# Connection Pool Settings
DB_POOL_MIN=2
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT=30000

# SSL Mode: disable, allow, prefer, require
DB_SSL_MODE=disable

# ==========================================
# REDIS CACHE
# ==========================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0
REDIS_ENABLED=true
CACHE_TTL=3600
CACHE_MAX_SIZE=100

# ==========================================
# SUPABASE
# ==========================================
NEXT_PUBLIC_SUPABASE_URL=https://your-instance.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_JWT_SECRET=your_jwt_secret_here
SUPABASE_DB_CONNECTION_STRING=postgresql://postgres:password@db.supabase.co:5432/postgres

# ==========================================
# AUTHENTICATION & SECURITY
# ==========================================
# Generate with: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_key_here_32_characters_minimum

# Generate with: openssl rand -base64 32
SESSION_SECRET=your_session_secret_key_here

JWT_EXPIRATION=24h
JWT_REFRESH_EXPIRATION=7d
SESSION_DURATION=86400

# CORS Settings (comma-separated)
CORS_ORIGIN=http://localhost:3000,https://yourdomain.com
CORS_CREDENTIALS=true

# CSRF Protection
CSRF_PROTECTION_ENABLED=true
SECURITY_HEADERS_ENABLED=true

# ==========================================
# EMAIL
# ==========================================
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=your_sendgrid_api_key

# Alternative: SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@yourdomain.com

EMAIL_VERIFICATION_ENABLED=true
PASSWORD_RESET_ENABLED=true

# ==========================================
# FILE STORAGE
# ==========================================
# Type: local, s3, gcs
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./uploads
MAX_FILE_SIZE=10485760

# AWS S3 (if using S3)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
S3_BUCKET=jga-enterprise-bucket
S3_ENDPOINT=https://s3.amazonaws.com

# Google Cloud Storage (if using GCS)
GCS_PROJECT_ID=your-gcs-project
GCS_BUCKET=jga-enterprise-bucket

# ==========================================
# PAYMENT PROCESSING
# ==========================================
# Stripe
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
STRIPE_PAYMENT_SUCCESS_URL=https://yourapp.com/pay/success

# Or PayPal
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret

CURRENCY=USD

# ==========================================
# MONITORING & ANALYTICS
# ==========================================
# Sentry Error Tracking
SENTRY_DSN=https://key@sentry.io/project-id
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=1.0.0

# Datadog APM (optional)
DD_ENABLED=false
DD_API_KEY=your_datadog_api_key

# Google Analytics
NEXT_PUBLIC_GA_ID=UA-xxxxxx-x

# Prometheus Metrics
PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090

# ==========================================
# FEATURE FLAGS
# ==========================================
FEATURE_A_B_TESTING=true
FEATURE_DARK_MODE=true
FEATURE_BETA_FEATURES=false

# ==========================================
# EXTERNAL SERVICES
# ==========================================
# Slack Integration
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/yourwebhook

# GitHub Integration
GITHUB_APP_ID=your_github_app_id

# Webhooks
WEBHOOK_SIGNING_SECRET=your_webhook_signing_secret
WEBHOOK_RETRY_ATTEMPTS=3
WEBHOOK_RETRY_INTERVAL=60

# ==========================================
# DEVELOPMENT ONLY
# ==========================================
USE_MOCK_DATA=false
MOCK_DATA_SEED=12345
NEXT_PUBLIC_HOT_RELOAD=true
ENABLE_DEV_TOOLS=true
ENABLE_MOCK_API=false
