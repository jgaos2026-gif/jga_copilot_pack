{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noEmit": true
  },
  "include": [
    "config/**/*.ts",
    "lib/**/*.ts",
    "lib/**/*.tsx",
    "tests/**/*.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    "__tests__/**/*.ts",
    "scripts/**/*.ts",
    "brics/**/*.ts"
  ]
}
