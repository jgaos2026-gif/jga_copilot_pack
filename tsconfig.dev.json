{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitReturns": false,
    "strict": false
  },
  "include": [
    "config/**/*.ts",
    "lib/**/*.ts",
    "lib/**/*.tsx",
    "tests/**/*.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    "__tests__/**/*.ts",
    "scripts/**/*.ts",
    "brics/**/*.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
